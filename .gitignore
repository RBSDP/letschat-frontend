# ==========================================
# 1. BUILD ARTIFACTS
# Compiled Java classes and Maven output
# ==========================================
target/
*.class

# Package Files
*.jar
*.war
*.ear

# ==========================================
# 2. IDE SETTINGS (Personalized)
# Environment-specific editor configurations
# ==========================================
# IntelliJ IDEA
.idea/
*.iml

# Eclipse
.settings/
.project
.classpath
.factorypath
bin/

# VS Code
.vscode/

# ==========================================
# 3. SECRETS & LOCAL CONFIG
# Never commit credentials or local overrides
# ==========================================
.env
application-local.properties
application-local.yml

# ==========================================
# 4. SYSTEM & LOGS
# OS-generated files and runtime logs
# ==========================================
*.log
.DS_Store
Thumbs.db

# ==========================================
# 5. MAVEN WRAPPER EXCEPTIONS
# Keep scripts, ignore binary if preferred
# ==========================================
!/.mvn/wrapper/maven-wrapper.jar
